# Required for transcript generation
GEMINI_API_KEY=your_gemini_api_key_here

# Default first-run storage is ~/Documents/Meetlify
# You can override the root, or override the subfolders individually.
MEETLIFY_STORAGE_ROOT=~/Documents/Meetlify
MEETLIFY_RECORDINGS_DIR=Recordings
MEETLIFY_TRANSCRIPTS_DIR=Transcripts

# Optional MP3 export tuning
MEETLIFY_MP3_BITRATE_KBPS=96
MEETLIFY_MP3_CHUNK_SIZE_MB=90
